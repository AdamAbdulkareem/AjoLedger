# Copy to .env and adjust as needed.

# Live backend base URL (no trailing slash).
EXPO_PUBLIC_API_URL=https://ajoledger-backend.onrender.com/api/v1

# Optional crash reporting (requires a native rebuild after first install).
EXPO_PUBLIC_SENTRY_DSN=
# Set to true to capture events while developing.
# EXPO_PUBLIC_SENTRY_DEBUG=true

# EAS build source maps — set in EAS secrets, not committed.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=ajoledger
