# Copy to .env and adjust as needed.

# Live backend base URL (no trailing slash).
# Production: https://ajoledger-backend.onrender.com/api/v1
EXPO_PUBLIC_API_URL=https://ajoledger-backend.onrender.com/api/v1

# true  = use mocks for PIN, home, profile, payout, etc.
# false = all API calls go to EXPO_PUBLIC_API_URL
EXPO_PUBLIC_USE_MOCK_AUTH=true

# true  = POST /auth/register and POST /auth/login use the live backend
EXPO_PUBLIC_USE_LIVE_AUTH=true
