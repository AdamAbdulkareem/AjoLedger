# Copy to .env and adjust as needed.

# Live backend base URL (no trailing slash).
EXPO_PUBLIC_API_URL=https://ajoledger-backend.onrender.com/api/v1

# Google Sign-In (native dev/EAS builds only — requires rebuild after setting).
#
# Get these from Google Cloud Console OAuth 2.0 clients for com.thecodestark.ajoledger:
#   EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID  — Web client (SDK uses this on Android)
#   EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID  — iOS client (required on iPhone/iPad)
#
# Android also needs a separate Android OAuth client in Console (package + SHA-1).
# Do NOT commit real IDs here if this file is ever tracked; use .env locally and
# `eas env:create` for cloud builds.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Optional crash reporting (requires a native rebuild after first install).
EXPO_PUBLIC_SENTRY_DSN=
# Set to true to capture events while developing.
# EXPO_PUBLIC_SENTRY_DEBUG=true

# EAS build source maps — set in EAS secrets, not committed.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=ajoledger
